# Shared
APP_ENV=production
TZ=Asia/Jakarta
LETSENCRYPT_EMAIL=ops@example.com

# Public routing
DASHBOARD_HOST=dashboard.zxmail.site
NEXT_PUBLIC_APP_NAME=zxMail
NEXT_PUBLIC_API_BASE_URL=https://dashboard.zxmail.site

# Backend
APP_NAME=zxmail-api
HTTP_PORT=8080
FRONTEND_ORIGIN=https://dashboard.zxmail.site
CORS_ALLOW_ORIGINS=https://dashboard.zxmail.site
COOKIE_DOMAIN=.zxmail.site
SHUTDOWN_TIMEOUT_SECONDS=10
DATABASE_URL=postgres://zxmail:replace-with-strong-password@postgres:5432/zxmail?sslmode=disable
REDIS_URL=redis://redis:6379/0
JWT_SECRET=replace-with-long-random-value
JWT_TTL_HOURS=24
LOGIN_MAX_FAILURES=5
LOGIN_FAILURE_WINDOW_MINUTES=10
LOGIN_LOCKOUT_MINUTES=15
FIRST_ADMIN_EMAIL=admin@zxmail.site
FIRST_ADMIN_PASSWORD=replace-with-strong-password
ENCRYPTION_KEY_ID=legacy-v1
ENCRYPTION_KEY=replace-with-32-byte-random-value
# Base64-encoded key material for new writes. Keep legacy ENCRYPTION_KEY during migration if old data exists.
ENCRYPTION_KEYS=key2:cmVwbGFjZS13aXRoLTMyeXRlLWJhc2U2NC1rZXktbWF0ZXJpYWw=
ACTIVE_ENCRYPTION_KEY_ID=key2

# Postal integration
# Postal is expected to run externally or in a separate dedicated stack for Production v1.
POSTAL_BASE_URL=https://postal.zxmail.site
POSTAL_API_KEY=replace-me
POSTAL_WEBHOOK_SECRET=replace-me
SMTP_PUBLIC_HOST=smtp.zxmail.site
SMTP_HOST=smtp.zxmail.site
SMTP_PORT_STARTTLS=587
SMTP_PORT_TLS=465

# Frontend runtime
PORT=3000

# PostgreSQL
POSTGRES_IMAGE=postgres:17-alpine
POSTGRES_DB=zxmail
POSTGRES_USER=zxmail
POSTGRES_PASSWORD=replace-with-strong-password

# Redis
REDIS_IMAGE=redis:7-alpine

# Reverse proxy
CADDY_IMAGE=caddy:2.10-alpine
